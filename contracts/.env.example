# ─── Deployer (NEVER commit the filled-in version) ────────────────────
# Generate with: cast wallet new
# Fund with ~0.005 ETH on Base mainnet for deployment gas.
PRIVATE_KEY=0x_64_hex_chars_here

# ─── RPCs ─────────────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Verification ─────────────────────────────────────────────────────
# Get from https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key

# ─── Optional ─────────────────────────────────────────────────────────
# CHAIN=base               # alias used by `forge script --rpc-url $CHAIN`
